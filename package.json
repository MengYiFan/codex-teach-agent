{
  "name": "teaching-content-generation-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "pnpm --filter @tcg/web dev",
    "dev:api": "pnpm --filter @tcg/api dev",
    "dev:agent": "pnpm --filter @tcg/agent dev",
    "dev:worker": "pnpm --filter @tcg/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check:conflicts": "bash -lc '! rg -n \"^(<<<<<<<|=======|>>>>>>>)\" .'"
  },
  "devDependencies": {}
}
